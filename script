                        local targetPart = obj:FindFirstChild("Head") or obj:FindFirstChild("HumanoidRootPart")
                        if targetPart then
                            applyVisualESP(targetPart, Color3.fromRGB(255, 0, 0), "ZOMBIE")
                        end
                    end
                end
            end

            for _, obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("Model") or obj:IsA("BasePart") then
                    local name = string.lower(obj.Name)
                    
                    if string.find(name, "mystery") or name == "box" or name == "chest" then
                        applyVisualESP(obj, Color3.fromRGB(255, 255, 0), "Mystery Box")
                    elseif string.find(name, "perk") or string.find(name, "revive") or string.find(name, "jugg") or string.find(name, "speed") or string.find(name, "cola") then
