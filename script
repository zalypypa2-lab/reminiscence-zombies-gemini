if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

pcall(function()
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Gemini Hub";
        Text = "Script Loaded Successfully!";
        Duration = 5;
    })
end)

local function applyESP(model, color)
    if not model or model:FindFirstChild("Gemini_ESP") then return end
    local highlight = Instance.new("Highlight")
    highlight.Name = "Gemini_ESP"
    highlight.FillColor = color
    highlight.FillTransparency = 0.5
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.OutlineTransparency = 0.2
    highlight.Parent = model
end

task.spawn(function()
    while task.wait(2) do
        pcall(function()
            for _, obj in pairs(workspace:GetChildren()) do
                if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj ~= LocalPlayer.Character then
                    if not Players:GetPlayerFromCharacter(obj) then
                        applyESP(obj, Color3.fromRGB(255, 0, 0))
                    end
                end
            end
            
            for _, obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("Model") or obj:IsA("BasePart") then
                    local name = string.lower(obj.Name)
                    if string.find(name, "box") or string.find(name, "mystery") then
                        applyESP(obj, Color3.fromRGB(255, 255, 0))
                    elseif string.find(name, "perk") or string.find(name, "cola") then
                        applyESP(obj, Color3.fromRGB(0, 255, 0))
                    end
                end
            end
        end)
    end
end)

task.spawn(function()
    while task.wait(2) do
        pcall(function()
            for _, tool in pairs(LocalPlayer.Backpack:GetChildren()) do
                if tool:IsA("Tool") then
                    for _, val in pairs(tool:GetDescendants()) do
