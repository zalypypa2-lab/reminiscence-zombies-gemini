task.spawn(function()
    while task.wait(0.3) do
        pcall(function()
            local character = LocalPlayer.Character
            if character then
                local tool = character:FindFirstChildOfClass("Tool")
                if tool then
                    for _, subItem in pairs(tool:GetDescendants()) do
                        if subItem:IsA("IntValue") or subItem:IsA("NumberValue") then
                            local lowerName = string.lower(subItem.Name)
                            if string.find(lowerName, "ammo") or string.find(lowerName, "clip") or string.find(lowerName, "mag") or string.find(lowerName, "reserve") then
                                subItem.Value = 999
                            end
                        end
                    end
                end
            end
        end)
    end
end)
