local createdESPElements = {}

local function createToggle(name, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 35)
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    btn.TextColor3 = Color3.fromRGB(255, 80, 80)
    btn.Text = name .. " : OFF"
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 14
    btn.Parent = Scroll
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = btn

    local state = false
    btn.MouseButton1Click:Connect(function()
        state = not state
        if state then
            btn.BackgroundColor3 = Color3.fromRGB(40, 60, 40)
            btn.TextColor3 = Color3.fromRGB(80, 255, 80)
            btn.Text = name .. " : ON"
        else
            btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            btn.TextColor3 = Color3.fromRGB(255, 80, 80)
            btn.Text = name .. " : OFF"
        end
        callback(state)
    end)
end

local function applyVisualESP(object, color, text)
    if not object or object:FindFirstChild("Gemini_ESP_Root") then return end
    
    local root = Instance.new("Folder")
    root.Name = "Gemini_ESP_Root"
    root.Parent = object
    table.insert(createdESPElements, root)

    local bbg = Instance.new("BillboardGui")
    bbg.Name = "Gemini_Billboard"
    bbg.Size = UDim2.new(0, 140, 0, 30)
    bbg.AlwaysOnTop = true
    bbg.StudsOffset = Vector3.new(0, 3, 0)
    bbg.Parent = root

    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1, 0, 1, 0)
    txt.BackgroundTransparency = 1
    txt.TextColor3 = color
    txt.TextSize = 14
    txt.Text = text
    txt.Font = Enum.Font.SourceSansBold
    txt.TextStrokeTransparency = 0
    txt.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    txt.Parent = bbg

    local boxBbg = Instance.new("BillboardGui")
    boxBbg.Name = "Gemini_Box"
    boxBbg.Size = UDim2.new(3, 0, 4, 0)
    boxBbg.AlwaysOnTop = true
    boxBbg.Parent = root

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundTransparency = 1
    frame.BorderColor3 = color
    frame.BorderSizePixel = 2
    frame.Parent = boxBbg
end

local function clearESP()
    for _, el in pairs(createdESPElements) do
        if el and el.Parent then pcall(function() el:Destroy() end) end
    end
    table.clear(createdESPElements)
end

createToggle("Zombie ESP", function(val)
    zombieESP = val
    if not zombieESP then clearESP() end
end)

createToggle("Perks & Box ESP", function(val)
    worldESP = val
    if not worldESP then clearESP() end
end)

createToggle("Craft Parts ESP", function(val)
    partsESP = val
    if not partsESP then clearESP() end
end)

task.spawn(function()
    while task.wait(1.5) do
        pcall(function()
            if zombieESP then
                for _, obj in pairs(workspace:GetDescendants()) do
                    if obj:IsA("Humanoid") and obj.Parent and obj.Parent ~= LocalPlayer.Character then
                        local model = obj.Parent
                        if not Players:GetPlayerFromCharacter(model) and model:FindFirstChild("Head") then
                            applyVisualESP(model.Head, Color3.fromRGB(255, 0, 0), "ZOMBIE")
                        end
                    end
                end
            end
        end)
    end
end)

task.spawn(function()
    while task.wait(2.5) do
        pcall(function()
            if worldESP or partsESP then
                for _, obj in pairs(workspace:GetDescendants()) do
                    local name = string.lower(obj.Name)
                    if obj:IsA("Model") or obj:IsA("BasePart") then
                        if worldESP and (string.find(name, "revive") or string.find(name, "jugg") or string.find(name, "perk") or string.find(name, "speed") or string.find(name, "cola") or obj:FindFirstChild("PackAPunch")) then
                            applyVisualESP(obj, Color3.fromRGB(0, 255, 0), "Perk Machine")
                        elseif worldESP and (string.find(name, "box") or string.find(name, "mystery") or string.find(name, "chest")) then
                            applyVisualESP(obj, Color3.fromRGB(255, 255, 0), "Mystery Box")
                        elseif partsESP and (string.find(name, "part") or string.find(name, "craft") or string.find(name, "item") or string.find(name, "component")) then
                            if not obj:FindFirstChild("Lava") and not string.find(name, "wall") and not string.find(name, "floor") then
                                applyVisualESP(obj, Color3.fromRGB(0, 255, 255), "Craft Part")
                            end
                        end
                    end
                end
            end
        end)
    end
end)

