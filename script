if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

pcall(function()
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Gemini Hub";
        Text = "V3 Fixed Activated!";
        Duration = 4;
    })
end)

local function applyBoxESP(object, color, text)
    if not object or object:FindFirstChild("Gemini_Billboard") then return end
    
    local bbg = Instance.new("BillboardGui")
    bbg.Name = "Gemini_Billboard"
    bbg.Size = UDim2.new(0, 120, 0, 30)
    bbg.AlwaysOnTop = true
    bbg.StudsOffset = Vector3.new(0, 3, 0)
    bbg.Parent = object

    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1, 0, 1, 0)
    txt.BackgroundTransparency = 1
    txt.TextColor3 = color
    txt.TextSize = 14
    txt.Text = text
    txt.Font = Enum.Font.SourceSansBold
    txt.TextStrokeTransparency = 0
    txt.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    txt.Parent = bbg
end

task.spawn(function()
    while task.wait(1.5) do
        pcall(function()
            -- 1. Подсветка зомби
            for _, obj in pairs(workspace:GetChildren()) do
                if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj ~= LocalPlayer.Character then
                    if not Players:GetPlayerFromCharacter(obj) and obj:FindFirstChild("Head") then
                        applyBoxESP(obj.Head, Color3.fromRGB(255, 0, 0), "ZOMBIE")
                    end
                end
            end

            -- 2. Умная подсветка только Кликабельных предметов (Коробка, Перки, Детали)
            for _, obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("ProximityPrompt") or obj:IsA("ClickDetector") then
                    local target = obj.Parent
                    if target and (target:IsA("Model") or target:IsA("BasePart")) then
                        local name = string.lower(target.Name)
                        local promptText = obj:IsA("ProximityPrompt") and string.lower(obj.ObjectText .. obj.ActionText) or ""
                        
                        if string.find(name, "box") or string.find(name, "mystery") or string.find(promptText, "box") or string.find(promptText, "mystery") then
                            applyBoxESP(target, Color3.fromRGB(255, 255, 0), "Mystery Box")
                        elseif string.find(name, "revive") or string.find(name, "jugg") or string.find(name, "perk") or string.find(name, "speed") or string.find(promptText, "perk") or string.find(promptText, "cola") then
                            applyBoxESP(target, Color3.fromRGB(0, 255, 0), "Perk Machine")
                        elseif string.find(name, "part") or string.find(name, "craft") or string.find(name, "item") or string.find(promptText, "part") or string.find(promptText, "craft") or string.find(promptText, "take") then
                            applyBoxESP(target, Color3.fromRGB(0, 255, 255), "Craft Part")
                        end
                    end
                end
            end
        end)
    end
end)

