local function createToggle(name, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 35)
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    btn.TextColor3 = Color3.fromRGB(255, 80, 80)
    btn.Text = name .. " : OFF"
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 14
    btn.Parent = Scroll
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = btn

    local state = false
    btn.MouseButton1Click:Connect(function()
        state = not state
        if state then
            btn.BackgroundColor3 = Color3.fromRGB(40, 60, 40)
            btn.TextColor3 = Color3.fromRGB(80, 255, 80)
            btn.Text = name .. " : ON"
        else
            btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            btn.TextColor3 = Color3.fromRGB(255, 80, 80)
            btn.Text = name .. " : OFF"
        end
        callback(state)
    end)
end

-- Новая плавная 3D обводка (Не лагает)
local function applyVisualESP(object, color, text)
    if not object or object:FindFirstChild("Gemini_ESP_Root") then return end
    
    -- Проверка высоты (если объект глубоко под картой — игнорируем)
    local position = object:IsA("Model") and (object.PrimaryPart and object.PrimaryPart.Position) or (object:IsA("BasePart") and object.Position)
    if position and position.Y < -50 then return end

    local root = Instance.new("Folder")
    root.Name = "Gemini_ESP_Root"
    root.Parent = object
    table.insert(createdESPElements, root)

    -- Неоновый контур вокруг всей модели
    local box = Instance.new("SelectionBox")
    box.Adornee = object
    box.Color3 = color
    box.LineThickness = 0.05
    box.SurfaceTransparency = 0.8
    box.Parent = root

    local bbg = Instance.new("BillboardGui")
    bbg.Name = "Gemini_Billboard"
    bbg.Size = UDim2.new(0, 140, 0, 30)
    bbg.AlwaysOnTop = true
    bbg.StudsOffset = Vector3.new(0, 3, 0)
    bbg.Parent = root

    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1, 0, 1, 0)
    txt.BackgroundTransparency = 1
    txt.TextColor3 = color
    txt.TextSize = 14
    txt.Text = text
    txt.Font = Enum.Font.SourceSansBold
    txt.TextStrokeTransparency = 0
    txt.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    txt.Parent = bbg
end

local function clearESP()
    for _, el in pairs(createdESPElements) do
        if el and el.Parent then pcall(function() el:Destroy() end) end
    end
    table.clear(createdESPElements)
end

createToggle("Zombie ESP", function(val)
    zombieESP = val
    if not zombieESP then clearESP() end
end)

createToggle("Perks & Box ESP", function(val)
    worldESP = val
    if not worldESP then clearESP() end
end)

createToggle("Craft Parts ESP", function(val)
    partsESP = val
    if not partsESP then clearESP() end
end)

-- Оптимизированный поиск зомби только на арене
task.spawn(function()
    while task.wait(1.5) do
        pcall(function()
            if zombieESP then
                for _, obj in pairs(workspace:GetChildren()) do
                    if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj ~= LocalPlayer.Character then
                        if not Players:GetPlayerFromCharacter(obj) and obj:FindFirstChild("Head") and obj.Humanoid.Health > 0 then
                            applyVisualESP(obj, Color3.fromRGB(255, 0, 0), "ZOMBIE")
                        end
                    end
                end
            end
        end)
    end
end)

-- Строгий поиск предметов без перегрузки процессора
task.spawn(function()
    while task.wait(3) do
        pcall(function()
            if worldESP or partsESP then
                for _, obj in pairs(workspace:GetDescendants()) do
                    if obj:IsA("Model") then
                        local name = string.lower(obj.Name)
                        -- Полный игнор мусорных текстур карты
                        if not string.find(name, "part") and not string.find(name, "wall") and not string.find(name, "floor") and not string.find(name, "map") and not string.find(name, "lava") and not string.find(name, "leaf") then
                            if worldESP and (string.find(name, "mystery") or name == "box" or name == "chest") then
                                applyVisualESP(obj, Color3.fromRGB(255, 255, 0), "Mystery Box")
                            elseif worldESP and (string.find(name, "revive") or string.find(name, "jugg") or string.find(name, "perk") or string.find(name, "speed") or string.find(name, "cola")) then
                                applyVisualESP(obj, Color3.fromRGB(0, 255, 0), "Perk Machine")
                            elseif partsESP and (string.find(name, "craft") or name == "component" or name == "item") then
                                applyVisualESP(obj, Color3.fromRGB(0, 255, 255), "Craft Part")
                            end
                        end
                    end
                end
            end
        end)
    end
end)

