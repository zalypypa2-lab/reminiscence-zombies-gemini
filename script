if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

pcall(function()
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Gemini Hub";
        Text = "V4 Balanced Engine!";
        Duration = 4;
    })
end)

local function applyBoxESP(object, color, text)
    if not object or object:FindFirstChild("Gemini_Billboard") then return end
    
    local bbg = Instance.new("BillboardGui")
    bbg.Name = "Gemini_Billboard"
    bbg.Size = UDim2.new(0, 140, 0, 30)
    bbg.AlwaysOnTop = true
    bbg.StudsOffset = Vector3.new(0, 3, 0)
    bbg.Parent = object

    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1, 0, 1, 0)
    txt.BackgroundTransparency = 1
    txt.TextColor3 = color
    txt.TextSize = 14
    txt.Text = text
    txt.Font = Enum.Font.SourceSansBold
    txt.TextStrokeTransparency = 0
    txt.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    txt.Parent = bbg
end

task.spawn(function()
    while task.wait(1.5) do
        pcall(function()
            -- 1. Сверхточный поиск Зомби
            for _, obj in pairs(workspace:GetChildren()) do
                if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj ~= LocalPlayer.Character then
                    if not Players:GetPlayerFromCharacter(obj) and obj:FindFirstChild("Head") then
                        applyBoxESP(obj.Head, Color3.fromRGB(255, 0, 0), "ZOMBIE")
                    end
                end
            end

            -- 2. Умное сканирование только КРУПНЫХ объектов (минуя кирпичи стен)
            for _, obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("Model") then
                    local name = string.lower(obj.Name)
                    
                    if string.find(name, "mystery") or name == "box" or name == "chest" then
                        applyBoxESP(obj, Color3.fromRGB(255, 255, 0), "Mystery Box")
                    elseif string.find(name, "perk") or string.find(name, "revive") or string.find(name, "jugg") or string.find(name, "speed") or string.find(name, "cola") then
                        applyBoxESP(obj, Color3.fromRGB(0, 255, 0), "Perk Machine")
                    elseif string.find(name, "craft") or string.find(name, "part") or string.find(name, "component") then
                        -- Игнорируем блоки лавы и стен, ищем только уникальные детали
                        if not obj:FindFirstChild("Lava") and not string.find(name, "wall") then
                            applyBoxESP(obj, Color3.fromRGB(0, 255, 255), "Craft Part")
                        end
                    end
                end
            end
        end)
    end
end)

task.spawn(function()
    while task.wait(0.5) do
        pcall(function()
            -- Агрессивный перебор всех папок оружия для бесконечных патронов
            local targetFolder = LocalPlayer.Character or LocalPlayer:FindFirstChild("Backpack")
            if targetFolder then
                for _, item in pairs(targetFolder:GetDescendants()) do
                    if item:IsA("IntValue") or item:IsA("NumberValue") then
                        local n = string.lower(item.Name)
                        if string.find(n, "ammo") or string.find(n, "clip") or string.find(n, "mag") or string.find(n, "reserve") then
                            item.Value = 999
                        end
                    end
                end
            end
        end)
    end
end)
