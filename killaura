local function getKnife()
    if not LocalPlayer.Character then return nil end
    local weaponNames = {"knife", "sword", "machete", "combat", "blade", "bat", "axe", "crowbar", "katana"}
    
    for _, item in pairs(LocalPlayer.Character:GetChildren()) do
        if item:IsA("Tool") then
            return item
        end
    end
    
    for _, item in pairs(workspace:GetDescendants()) do
        if item:IsA("Tool") and item.Parent == LocalPlayer.Character then
            return item
        end
    end
    
    for _, name in pairs(weaponNames) do
        for _, item in pairs(workspace:GetDescendants()) do
            if string.find(string.lower(item.Name), name) and item:IsA("Tool") then
                local character = item:FindFirstAncestorOfClass("Model")
                if character == LocalPlayer.Character then
                    return item
                end
            end
        end
    end
    return nil
end

