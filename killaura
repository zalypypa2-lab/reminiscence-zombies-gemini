task.spawn(function()
    while task.wait(0.3) do
        if killauraActive and not logFrozen then
            local zombies = {}
            local zombieNames = {}
            local logText = ""

            local function findZombiesIn(parent)
                for _, obj in pairs(parent:GetChildren()) do
                    if obj:IsA("Model") then
                        local hum = obj:FindFirstChild("Humanoid")
                        if hum and hum.Health > 0 then
                            if not Players:GetPlayerFromCharacter(obj) then
                                table.insert(zombies, obj)
                                if #zombieNames < 3 then
                                    table.insert(zombieNames, obj.Name)
                                end
                            end
                        end
                    end
                    if obj:IsA("Folder") or obj:IsA("Model") then
                        findZombiesIn(obj)
                    end
                end
            end

            local zombiesFolder = workspace:FindFirstChild("Zombies")
            if zombiesFolder then
                findZombiesIn(zombiesFolder)
            else
                findZombiesIn(workspace)
            end

            if #zombies == 0 then
                LogLabel.Text = "No zombies found!"
                continue
            end

            methodIndex = (methodIndex % #attackMethods) + 1
            local method = attackMethods[methodIndex]
            local success, err = pcall(function()
                for _, zombie in ipairs(zombies) do
                    method.func(zombie)
                end
            end)

            logText = "Found: " .. #zombies .. " | " .. table.concat(zombieNames, ", ") .. "\n"
            logText = logText .. "Method " .. methodIndex .. ": " .. method.name
            if not success then
                logText = logText .. " ERROR: " .. tostring(err)
            else
                logText = logText .. " sent."
            end

            LogLabel.Text = logText
        end
    end
end)
