if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui", 10)
local Lighting = game:GetService("Lighting")

if not PlayerGui then return end

if PlayerGui:FindFirstChild("ZombieAttackGUI") then
    PlayerGui.ZombieAttackGUI:Destroy()
end

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "ZombieAttackGUI"
ScreenGui.Parent = PlayerGui
ScreenGui.ResetOnSpawn = false
ScreenGui.DisplayOrder = 999999

local AttackButton = Instance.new("TextButton")
AttackButton.Size = UDim2.new(0, 160, 0, 45)
AttackButton.Position = UDim2.new(0.5, -80, 0.85, 0)
AttackButton.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
AttackButton.TextColor3 = Color3.fromRGB(255, 80, 80)
AttackButton.Text = "Attack: OFF"
AttackButton.Font = Enum.Font.GothamBold
AttackButton.TextSize = 16
AttackButton.Parent = ScreenGui

Instance.new("UICorner", AttackButton).CornerRadius = UDim.new(0, 8)
Instance.new("UIStroke", AttackButton).Color = Color3.fromRGB(150, 40, 40)
AttackButton.UIStroke.Thickness = 2

local Toggle = false

AttackButton.MouseButton1Click:Connect(function()
    Toggle = not Toggle
    if Toggle then
        AttackButton.BackgroundColor3 = Color3.fromRGB(15, 40, 15)
        AttackButton.TextColor3 = Color3.fromRGB(70, 255, 70)
        AttackButton.UIStroke.Color = Color3.fromRGB(30, 120, 30)
        AttackButton.Text = "Attack: ON"
    else
        AttackButton.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
        AttackButton.TextColor3 = Color3.fromRGB(255, 80, 80)
        AttackButton.UIStroke.Color = Color3.fromRGB(150, 40, 40)
        AttackButton.Text = "Attack: OFF"
    end
end)

task.spawn(function()
    while task.wait(0.15) do
        if Toggle then
            pcall(function()
                for _, v in pairs(workspace.Zombies:GetChildren()) do
                    if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                        game:GetService("Lighting").ETC:FireServer({
                            v.Humanoid,
                            math.huge,
                            "Damage\240\159\144\153",
                            false, false, false,
                            [8] = vector.create(0,0,0),
                            [9] = { HitS = 1, ConfirmedHit = 1 }
                        })
                    end
                end
            end)
        end
    end
end)
