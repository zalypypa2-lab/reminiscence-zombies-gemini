local function findRelevantEvents()
    local keywords = {"damage", "hit", "knife", "swing", "slash", "attack", "melee", "zombie", "weapon", "deal"}
    local relevant = {}
    local places = {
        {Lighting, "Lighting"},
        {ReplicatedStorage, "ReplicatedStorage"},
        {workspace, "Workspace"}
    }
    for _, place in ipairs(places) do
        for _, obj in pairs(place[1]:GetDescendants()) do
            if obj:IsA("RemoteEvent") then
                local lowerName = obj.Name:lower()
                for _, kw in ipairs(keywords) do
                    if lowerName:find(kw) then
                        table.insert(relevant, place[2] .. "/" .. obj.Name)
                        break
                    end
                end
            end
        end
    end
    return relevant
end

ListEventsBtn.MouseButton1Click:Connect(function()
    local events = findRelevantEvents()
    local logText
    if #events == 0 then
        logText = "No damage-related events found!"
    else
        logText = "Relevant events (" .. #events .. "):\n"
        for i = 1, math.min(#events, 10) do
            logText = logText .. i .. ". " .. events[i] .. "\n"
        end
        if #events > 10 then
            logText = logText .. "... and " .. (#events - 10) .. " more"
        end
    end
    LogLabel.Text = logText
    logFrozen = true
end)

